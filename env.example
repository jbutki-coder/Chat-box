# Copy this file to .env for local testing.
# On Render, add these under Environment Variables instead.

# Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Use either a Twilio phone number OR a Twilio Messaging Service SID.
TWILIO_PHONE_NUMBER=+15551234567
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The private number that receives website notifications.
# Put your test phone number here in E.164 format, for example +18105551212.
NOTIFY_PHONE_NUMBER=+1YOURNUMBERHERE

# Comma-separated domains allowed to iframe this app.
# For first testing, leave as *. For tighter security later, use your WordPress domain.
# Example: ALLOWED_FRAME_ANCESTORS='self',https://yourdomain.org
ALLOWED_FRAME_ANCESTORS=*

# Optional local testing only. true means it logs the SMS instead of sending it.
DRY_RUN=false

# Optional anti-spam limit.
RATE_LIMIT_PER_10_MINUTES=5
